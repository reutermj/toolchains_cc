#/bin/bash -e
export PATH=/tmp/work/.build/x86_64-linux-musl/buildtools/bin:$PATH

# [INFO ]  Installing MPFR for host
mkdir -p '/tmp/work/.build/x86_64-linux-musl/build/build-mpfr-host-x86_64-build_pc-linux-gnu'
cd '/tmp/work/.build/x86_64-linux-musl/build/build-mpfr-host-x86_64-build_pc-linux-gnu'
CC='x86_64-build_pc-linux-gnu-gcc' CFLAGS='-O2 -g -pipe -I/tmp/work/.build/x86_64-linux-musl/buildtools/include  ' LDFLAGS='-L/tmp/work/.build/x86_64-linux-musl/buildtools/lib  ' '/usr/bin/bash' '/tmp/work/.build/x86_64-linux-musl/src/mpfr/configure' '--build=x86_64-build_pc-linux-gnu' '--host=x86_64-build_pc-linux-gnu' '--prefix=/tmp/work/.build/x86_64-linux-musl/buildtools' '--enable-thread-safe' '--with-gmp=/tmp/work/.build/x86_64-linux-musl/buildtools' '--disable-shared' '--enable-static'
'make' '-j33' '-l'
'make' 'install' 'DESTDIR='
