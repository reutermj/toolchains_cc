#/bin/bash -e
export PATH=/tmp/work/.build/x86_64-linux-musl/buildtools/bin:$PATH

# [INFO ]  Installing zstd for host
mkdir -p '/tmp/work/.build/x86_64-linux-musl/build/build-zstd-host-x86_64-build_pc-linux-gnu'
cd '/tmp/work/.build/x86_64-linux-musl/build/build-zstd-host-x86_64-build_pc-linux-gnu'
'make' '-j33' '-l' '-C' '/tmp/work/.build/x86_64-linux-musl/src/zstd/lib' 'libzstd.a-nomt-release' 'BUILD_DIR=/tmp/work/.build/x86_64-linux-musl/build/build-zstd-host-x86_64-build_pc-linux-gnu' 'CC=x86_64-build_pc-linux-gnu-gcc' 'AS=x86_64-build_pc-linux-gnu-as' 'CFLAGS=-O2 -g -pipe -I/tmp/work/.build/x86_64-linux-musl/buildtools/include  ' 'LDFLAGS=-L/tmp/work/.build/x86_64-linux-musl/buildtools/lib  '
'make' '-C' '/tmp/work/.build/x86_64-linux-musl/src/zstd/lib' 'install-static' 'install-includes' 'BUILD_DIR=/tmp/work/.build/x86_64-linux-musl/build/build-zstd-host-x86_64-build_pc-linux-gnu' 'PREFIX=/tmp/work/.build/x86_64-linux-musl/buildtools'
