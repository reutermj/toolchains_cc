#/bin/bash -e
export PATH=/tmp/output/bin:/tmp/work/.build/x86_64-linux-musl/buildtools/bin:$PATH

# [INFO ]  Installing C library
mkdir -p /tmp/work/.build/x86_64-linux-musl/build/build-libc
cd /tmp/work/.build/x86_64-linux-musl/build/build-libc

env CROSS_COMPILE=x86_64-linux-musl- \
    /tmp/work/.build/x86_64-linux-musl/src/musl/configure \
        --host=x86_64-linux-musl \
        --target=x86_64-linux-musl \
        --prefix=/usr \
        --libdir=/usr/lib \
        --disable-gcc-wrapper \
        --enable-shared \
        --enable-optimize=auto
make -j33 -l
make DESTDIR=/tmp/output/x86_64-linux-musl/sysroot install
