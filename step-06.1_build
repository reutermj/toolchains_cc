#/bin/bash -e
export PATH=/tmp/work/.build/x86_64-linux-musl/buildtools/bin:$PATH

# [INFO ]  Installing zlib for host
mkdir -p /tmp/work/.build/x86_64-linux-musl/build/build-zlib-host-x86_64-build_pc-linux-gnu
cd /tmp/work/.build/x86_64-linux-musl/build/build-zlib-host-x86_64-build_pc-linux-gnu

env CFLAGS="-O2 -g -pipe -I/tmp/work/.build/x86_64-linux-musl/buildtools/include" \
    LDFLAGS="-L/tmp/work/.build/x86_64-linux-musl/buildtools/lib" \
    CHOST=x86_64-linux-gnu \
    /tmp/work/.build/x86_64-linux-musl/src/zlib/configure \
        --prefix=/tmp/work/.build/x86_64-linux-musl/buildtools \
        --static
        
make -j33 -l
make install
