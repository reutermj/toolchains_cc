#/bin/bash -e
export PATH=/tmp/work/.build/x86_64-linux-musl/buildtools/bin:$PATH

# [INFO ]  Installing expat for host
mkdir -p '/tmp/work/.build/x86_64-linux-musl/build/build-expat-host-x86_64-build_pc-linux-gnu'
cd '/tmp/work/.build/x86_64-linux-musl/build/build-expat-host-x86_64-build_pc-linux-gnu'
CFLAGS='-O2 -g -pipe -I/tmp/work/.build/x86_64-linux-musl/buildtools/include  ' LDFLAGS='-L/tmp/work/.build/x86_64-linux-musl/buildtools/lib  ' '/usr/bin/bash' '/tmp/work/.build/x86_64-linux-musl/src/expat/configure' '--build=x86_64-build_pc-linux-gnu' '--host=x86_64-build_pc-linux-gnu' '--prefix=/tmp/work/.build/x86_64-linux-musl/buildtools' '--enable-static' '--without-docbook' '--disable-shared'
'make' '-j33' '-l'
'make' 'install' 'DESTDIR='
