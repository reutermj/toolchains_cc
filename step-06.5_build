#/bin/bash -e
export PATH=/tmp/work/.build/x86_64-linux-musl/buildtools/bin:$PATH

# [INFO ]  Installing ISL for host
cd /tmp/work/.build/x86_64-linux-musl/src/isl/
./autogen.sh

mkdir -p /tmp/work/.build/x86_64-linux-musl/build/build-isl-host-x86_64-build_pc-linux-gnu
cd /tmp/work/.build/x86_64-linux-musl/build/build-isl-host-x86_64-build_pc-linux-gnu

env CFLAGS="-O2 -g -pipe -I/tmp/work/.build/x86_64-linux-musl/buildtools/include" \
    CXXFLAGS="-O2 -g -pipe -I/tmp/work/.build/x86_64-linux-musl/buildtools/include" \
    LDFLAGS="-L/tmp/work/.build/x86_64-linux-musl/buildtools/lib" \
    /tmp/work/.build/x86_64-linux-musl/src/isl/configure \
        --build=x86_64-linux-gnu \
        --host=x86_64-linux-gnu \
        --prefix=/tmp/work/.build/x86_64-linux-musl/buildtools \
        --disable-shared \
        --enable-static \
        --with-gmp=system \
        --with-gmp-prefix=/tmp/work/.build/x86_64-linux-musl/buildtools \
        --with-clang=no

make -j33 -l
make install
