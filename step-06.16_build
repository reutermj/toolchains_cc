#/bin/bash -e
export PATH=/tmp/work/.build/x86_64-linux-musl/buildtools/bin:$PATH

# [INFO ]  Installing gdb server
mkdir -p '/tmp/work/.build/x86_64-linux-musl/build/build-gdb-server'
cd '/tmp/work/.build/x86_64-linux-musl/build/build-gdb-server'
CPP='x86_64-linux-musl-cpp' CC='x86_64-linux-musl-gcc' CXX='x86_64-linux-musl-g++' LD='x86_64-linux-musl-ld' CFLAGS='' CXXFLAGS='' LDFLAGS='' '/usr/bin/bash' '/tmp/work/.build/x86_64-linux-musl/src/gdb/configure' '--build=x86_64-build_pc-linux-gnu' '--host=x86_64-linux-musl' '--target=x86_64-linux-musl' '--prefix=/usr' '--with-build-sysroot=/tmp/output/x86_64-linux-musl/sysroot' '--includedir=/usr/include' '--disable-werror' '--disable-gdb' '--program-prefix=' '--enable-gdbserver' '--disable-inprocess-agent' '--without-uiout' '--disable-gdbtk' '--without-x' '--disable-sim' '--without-included-gettext' '--without-develop' '--sysconfdir=/etc' '--localstatedir=/var' '--with-pkgversion=crosstool-NG 1.28.0.3_a3fef85' '--disable-binutils' '--disable-ld' '--disable-gas' '--enable-threads' '--disable-nls'
'make' '-j33' '-l'
'make' 'install' 'DESTDIR=/tmp/output/x86_64-linux-musl/debug-root'
